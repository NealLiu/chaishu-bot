# 拆书工作流 环境变量配置
# 复制此文件为 .env 并填入实际值

# DeepSeek API (用于拆书 + 推荐)
# 获取地址: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=sk-your-key-here

# Obsidian Local REST API
# 插件: Community Plugins → Local REST API
# 端口默认 27124 (HTTPS)，API Key 在插件设置中获取
OBSIDIAN_API_KEY=your-obsidian-api-key
OBSIDIAN_API_URL=https://127.0.0.1:27124

# n8n 部署方式
# - local: 本地 Docker (docker run -p 5678:5678 n8nio/n8n)
# - cloud: n8n 云端 (n8n.io)
N8N_MODE=local
N8N_URL=http://localhost:5678
N8N_ENCRYPTION_KEY=change-me

# 工作流触发
# 每日拆书时间 (cron 表达式)
SCHEDULE_CRON="0 8 * * *"

# 飞书推送（可选，不配置则跳过推送功能）
# 获取地址: https://open.feishu.cn/app
# FEISHU_APP_ID=cli-xxxxxxxx
# FEISHU_APP_SECRET=xxxxxx
# FEISHU_CHAT_ID=oc_xxxxxxxx
# FEISHU_WEBHOOK=https://open.feishu.cn/open-apis/bot/v2/hook/xxxxxxxx

# MD2Card API 渲染（推荐，比 Puppeteer 方案更稳定）
# 获取地址: https://md2card.com/zh/my/api-keys
# 不配置则自动降级到 Puppeteer 浏览器方案
MD2CARD_API_KEY=

# 可选: MD2Card 默认主题 (默认: warm)
# 可用: warm, apple-notes, xiaohongshu, minimal, glassmorphism 等
MD2CARD_TEMPLATE=温暖柔和

# 可选: 日志级别 (debug, info, warn, error)
LOG_LEVEL=info

# 飞书事件订阅（接收用户消息）
# 在飞书应用「事件订阅」页面配置 Request URL: http://YOUR_IP:19876/feishu-event
# FEISHU_VERIFY_TOKEN=your-verification-token
# FEISHU_EVENT_ENCRYPT_KEY=your-encrypt-key

# 阅读页面的公网地址（飞书卡片点击跳转的目标）
# - 本机测试: http://127.0.0.1:19876
# - 同 WiFi 手机: http://192.168.x.x:19876（电脑局域网 IP）
# - 公网访问: 用 ngrok/Cloudflare Tunnel，填隧道地址
# PUBLIC_URL=http://127.0.0.1:19876

# 可选: 服务器端口
CHAISHU_PORT=19876
